# Copy this file to .env and fill in real values.
# NEVER commit the real .env file — it contains secrets.

ENVIRONMENT=development

# Comma-separated list of allowed frontend origins (no trailing slash).
FRONTEND_ORIGINS=http://localhost:5173
# Path to the downloaded service account JSON key file.
GOOGLE_SERVICE_ACCOUNT_FILE="service_account.json"

# Drive folder ID where per-property subfolders will be created
# (the "Property Photos" root folder — get this from its Drive URL).
GOOGLE_DRIVE_PARENT_FOLDER_ID= "1KmpXFBNg_qzrkvZVs7DFwMoeAhPYM3X0"

# Spreadsheet IDs (from each sheet's URL: /d/<THIS_PART>/edit)
GOOGLE_SHEET_PROPERTIES_ID= "1E7jvecjrSq5qwPSX_ptCA95fyNzpD0L70DfvPd6tNkE"
GOOGLE_SHEET_TESTIMONIALS_ID="1uBkRJG_pgLoq7xrU4rMg7RqZ5EDIm-WrAwGviz-XfAk"
GOOGLE_SHEET_ENQUIRIES_ID="1eRYhUzymnxgXpamavto6cm92niOjBQUOxc9m4NIGAQY"

PROPERTIES_SHEET_NAME="Properties"
TESTIMONIALS_SHEET_NAME="Testimonials"
ENQUIRIES_SHEET_NAME="Enquiries"

# Gmail account used to send notifications (use an App Password, not your
# normal password — requires 2-Step Verification enabled on the account).
GMAIL_ADDRESS="meinstinebhagur@gmail.com"
GMAIL_APP_PASSWORD="mansi+yash"
ADMIN_EMAIL="meinstinebhagur@gmail.com"

# Upload limits
MAX_UPLOAD_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
